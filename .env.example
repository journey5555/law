# open.law.go.kr 에서 신청한 API 인증값 (이메일 @ 앞 ID만)
# 예: orcaorca@naver.com → orcaorca
LAW_API_OC=your_oc_here

# SKT AIP 에이전트 Gateway
AGENT_ID=ed053b2a-1966-496e-8623-bb34a8334fd8
AGENT_API_KEY=your_api_key_here
# Windows SSL 오류 시 false
AGENT_VERIFY_SSL=true

# 판례 AI 요약 에이전트 (없으면 AI 요약 버튼 미표시)
SUMMARIZE_AGENT_ID=
SUMMARIZE_API_KEY=

# 법률판례질의 에이전트
LAW_PREC_AGENT_ID=
LAW_PREC_AGENT_API_KEY=

# 채팅 웹 서버
CHAT_HOST=127.0.0.1
CHAT_PORT=8080

# 로그 (DEBUG, INFO, WARNING)
LOG_LEVEL=INFO

# SKT AIP Knowledge API
# 방법 1: 토큰 직접 입력
KNOWLEDGE_TOKEN=
# 방법 2: 아이디/비번 → 자동 로그인 + 만료 시 자동 갱신 (KNOWLEDGE_TOKEN 비워두기)
KNOWLEDGE_USER=
KNOWLEDGE_PASSWORD=
KNOWLEDGE_LAW_REPO_ID=
KNOWLEDGE_PREC_REPO_ID=
# RAG 테스트용 요약본 저장 Knowledge
KNOWLEDGE_SUMM_REPO_ID=
